# Copia este archivo como .env para desarrollo local
# En Render, estas variables se configuran en el panel web (nunca subas el .env a GitHub)

# Contraseña del PDF encriptado de registroparteviajeros.com
PDF_PASSWORD=tu_contraseña_aqui

# Clave secreta que Make enviará en la cabecera X-Api-Secret
# Genera una clave aleatoria larga, por ejemplo con: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET=genera_una_clave_aleatoria_larga_aqui
